from flask import Flask, request
import requests

app = Flask(__name__)

# طلب التوكن من المستخدم
PAGE_ACCESS_TOKEN = input("🔑 أدخل توكن الصفحة: ").strip()
VERIFY_TOKEN = "123456"

# 🔍 التحقق من التوكن
def check_token():
    url = f"https://graph.facebook.com/v19.0/me?access_token={PAGE_ACCESS_TOKEN}"
    try:
        res = requests.get(url).json()
        if "error" in res:
            print("❌ التوكن غير صالح أو منتهي")
            return False
        else:
            print("✅ التوكن صحيح والبوت جاهز")
            return True
    except:
        print("❌ خطأ في الاتصال")
        return False

# Webhook Verification
@app.route("/webhook", methods=["GET"])
def verify():
    if request.args.get("hub.mode") == "subscribe" and request.args.get("hub.verify_token") == VERIFY_TOKEN:
        return request.args.get("hub.challenge")
    return "Verification failed"

# استقبال الرسائل
@app.route("/webhook", methods=["POST"])
def webhook():
    data = request.get_json()

    if data.get("object") == "page":
        for entry in data.get("entry", []):
            for event in entry.get("messaging", []):
                sender_id = event["sender"]["id"]

                if "message" in event:
                    text = event["message"].get("text", "")
                    print("📩 رسالة:", text)
                    send_message(sender_id, f"🤖 قلت: {text}")

    return "ok", 200

# إرسال رسالة
def send_message(recipient_id, text):
    url = f"https://graph.facebook.com/v19.0/me/messages?access_token={PAGE_ACCESS_TOKEN}"
    payload = {
        "recipient": {"id": recipient_id},
        "message": {"text": text}
    }
    requests.post(url, json=payload)

# الصفحة الرئيسية
@app.route("/", methods=["GET"])
def home():
    return "✅ البوت يعمل"

if __name__ == "__main__":
    if check_token():  # يتحقق قبل التشغيل
        print("🚀 تشغيل السيرفر على http://localhost:3000")
        app.run(port=3000)
    else:
        print("⛔ أوقف التشغيل بسبب توكن غير صالح")
